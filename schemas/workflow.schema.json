{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chaos.local/schemas/workflow.schema.json",
  "title": "ChaOS Workflow Specification",
  "type": "object",
  "required": ["name", "purpose", "stages", "evaluation"],
  "properties": {
    "name": { "type": "string" },
    "purpose": { "type": "string" },
    "stages": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["name", "purpose", "responsibilities", "failure_modes", "evaluation_methods"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["Trigger", "Input", "Processing", "Decision", "Action", "Feedback"]
          },
          "purpose": { "type": "string" },
          "responsibilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "failure_modes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evaluation_methods": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "evaluation": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}

